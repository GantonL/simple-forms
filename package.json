{
	"name": "simple-forms",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "node build/index.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:server": "vitest run --environment=node",
		"test:db:up": "docker compose -f docker-compose.test.yml up -d",
		"test:db:down": "docker compose -f docker-compose.test.yml down",
		"local:db:up": "docker compose -f docker-compose.local.yml up -d",
		"local:db:down": "docker compose -f docker-compose.local.yml down",
		"create:page": "bun run scripts/create-page.js",
		"create:md": "bun run scripts/create-markdown.js",
		"create:api-controller": "bun run scripts/create-api-controller.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@sveltejs/kit": "^2.68.0",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "^1.3.14",
		"@vitest/browser": "^3.2.6",
		"clsx": "^2.1.1",
		"drizzle-kit": "0.30.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.61.1",
		"prettier": "^3.9.0",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.62.0",
		"vite": "^6.4.3",
		"vitest": "^3.2.6",
		"vitest-browser-svelte": "^0.1.0"
	},
	"dependencies": {
		"@dicebear/collection": "^9.4.2",
		"@dicebear/core": "^9.4.2",
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@supabase/supabase-js": "^2.108.2",
		"@sveltejs/adapter-node": "^5.5.7",
		"@tanstack/table-core": "^8.21.3",
		"better-auth": "^1.6.22",
		"bits-ui": "^2.18.1",
		"drizzle-orm": "^0.44.7",
		"mode-watcher": "^1.1.0",
		"postgres": "^3.4.9",
		"rehype-add-classes": "^1.0.0",
		"signature_pad": "^5.1.3",
		"super-sitemap": "^2.0.3",
		"svelte-meta-tags": "^4.7.0",
		"sveltekit-i18n": "^2.4.2"
	}
}
